# Copy to terraform.tfvars and edit. terraform.tfvars is gitignored.

project_name = "aws-docs-agent"
environment  = "dev"
aws_region   = "us-east-1"
owner_email  = "you@example.com"

# Bedrock model IDs. Make sure your account has "Model access" granted
# for these in the Bedrock console (us-east-1 / us-west-2 are safest).
bedrock_chat_model_id  = "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
bedrock_embed_model_id = "amazon.titan-embed-text-v2:0"

# Leave create_app_runner = false for the first apply (provisions ECR + S3 +
# IAM). After pushing the first image, flip it on:
#   terraform apply -var "create_app_runner=true"
create_app_runner   = false
container_image_tag = "latest"

app_runner_cpu          = "1 vCPU"
app_runner_memory       = "2 GB"
app_runner_min_instances = 1
app_runner_max_instances = 2
