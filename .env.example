# Copy to .env and fill in. The app reads from environment variables.
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock model IDs. Override if your account has different model access.
# us.* prefix = cross-region inference profile (required by newer Anthropic
# models on Bedrock, bare model IDs are provisioned-throughput only).
BEDROCK_CHAT_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Vector index
INDEX_LOCAL_PATH=./data/index
# Optional: S3 location to read/write the FAISS index from. Leave blank for local-only.
INDEX_S3_BUCKET=
INDEX_S3_PREFIX=faiss/

# Ingestion knobs
INGEST_SOURCES_FILE=./config/sources.yaml
INGEST_CHUNK_TOKENS=750
INGEST_CHUNK_OVERLAP_TOKENS=80
INGEST_MAX_FILES_PER_REPO=400

# Agent knobs
AGENT_MAX_TOOL_CALLS=6
AGENT_TOP_K=6
AGENT_TEMPERATURE=0.1

# Optional: LangSmith tracing (leave blank to disable)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aws-docs-agent
LANGSMITH_TRACING=false
